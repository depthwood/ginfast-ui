# 开发环境
VITE_USER_NODE_ENV = test

# 路由模式 hash | history
VITE_ROUTER_MODE = hash

# 开发环境地址前缀 (一般 '/' 或 './' 都可以)
VITE_PUBLIC_PATH = '/test'

# 请求路径 管理系统/开发环境
VITE_APP_BASE_URL = '/'

# 分片上传配置
VITE_CHUNK_SIZE = 5242880
VITE_CHUNK_CONCURRENCY = 3
VITE_CHUNK_LARGE_FILE_THRESHOLD = 52428800
VITE_CHUNK_MAX_RETRY = 3
VITE_CHUNK_MAX_FILE_SIZE = 5368709120  # 最大文件大小 5GB